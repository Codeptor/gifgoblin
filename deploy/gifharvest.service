# systemd user unit. Install:
#   mkdir -p ~/.config/systemd/user
#   cp deploy/gifharvest.service ~/.config/systemd/user/
#   systemctl --user daemon-reload
#   systemctl --user enable --now gifharvest

[Unit]
Description=gifharvest - X/Twitter GIF scraper to Discord
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=%h/TwitterGIFharvest
ExecStart=%h/.local/bin/uv run gifharvest run
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
