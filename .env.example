# Discord (required to run the bot)
DISCORD_TOKEN=
GIF_CHANNEL_ID=
# Optional: send donor-account/cookie health alerts to a separate admin channel.
# Defaults to GIF_CHANNEL_ID when unset.
# ALERT_CHANNEL_ID=
# Try twscrape's stored-credential relogin once before sending donor alerts.
AUTO_RELOGIN=true
# Optional: sync slash commands instantly to one server instead of waiting ~1h for global sync
# GUILD_ID=

# Polling
POLL_MINUTES=10
SCRAPE_LIMIT=20
# On the first scrape of a newly tracked handle, post only the newest N gifs (rest marked seen)
BACKFILL_COUNT=3

# What counts as content
INCLUDE_RETWEETS=false
INCLUDE_VIDEOS=false
# React to pasted tweet links in Discord messages. Requires enabling
# "Message Content Intent" in the Discord Developer Portal for the bot.
MESSAGE_LINKS_ENABLED=false

# Posting
# 0 = auto (use the guild's upload limit, 10MB free / more if boosted)
MAX_UPLOAD_BYTES=0
# Converting mp4 "gifs" to real autoplaying+looping .gif files is the default (needs ffmpeg).
# Set CONVERT_TO_GIF=false to post the raw mp4 instead.
# Oversize or failed conversions fall back to the mp4 upload automatically.
CONVERT_TO_GIF=true
GIF_FPS=15
# Caps the gif's longest side (fit-in-box, never upscaled)
GIF_MAX_WIDTH=480
# /get only: convert a tweet's video to a real gif when it's this many seconds
# or shorter (0 disables). Longer videos and the poll loop always post mp4.
# Oversized conversions fall back to the mp4 (or an embed link) automatically.
VIDEO_GIF_MAX_SECONDS=5

# Storage
DB_PATH=data/gifharvest.db
ACCOUNTS_DB=data/accounts.db

LOG_LEVEL=INFO
